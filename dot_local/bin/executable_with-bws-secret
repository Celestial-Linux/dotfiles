#!/usr/bin/env nu

const usage = "Usage:
  with-bws-secret [--isolated] [--env-name NAME] SECRET_ID COMMAND [ARG...]
  with-bws-secret [--isolated] SECRET_ID... -- COMMAND [ARG...]

Fetch one or more Bitwarden Secrets Manager secrets and run COMMAND with those secrets injected.
By default, each secret's key becomes the environment variable name.
When passing multiple secret ids, separate the command with --.

Options:
  --isolated       Do not pass the current environment through to COMMAND.
  --env-name NAME  Use NAME as the environment variable instead of the secret key.
                  Only valid when passing one secret id.
  -h, --help       Show this help.

Examples:
  with-bws-secret 00000000-0000-0000-0000-000000000000 codex
  with-bws-secret 00000000-0000-0000-0000-000000000000 11111111-1111-1111-1111-111111111111 -- codex
  with-bws-secret --env-name OPENAI_API_KEY 00000000-0000-0000-0000-000000000000 env
  with-bws-secret --isolated 00000000-0000-0000-0000-000000000000 11111111-1111-1111-1111-111111111111 -- env"

const access_token_env = "BWS_AUTH_TOKEN"

def parse_flag_value [
    flag: string
    remaining: list<string>
] {
    if (($remaining | length) < 2) {
        print --stderr $"with-bws-secret: ($flag) requires a value"
        exit 64
    }

    $remaining.1
}

def validate_env_name [
    env_name: string
] {
    if ($env_name == "") or ($env_name | str contains "=") {
        print --stderr $"with-bws-secret: invalid environment variable name: ($env_name)"
        exit 64
    }
}

def fetch_secret [
    access_token: string
    secret_id: string
] {
    try {
        ^bws --access-token $access_token secret get $secret_id --output json | from json
    } catch { |err|
        print --stderr $"with-bws-secret: failed to fetch secret ($secret_id): ($err.msg)"
        let exit_code = ($env | get --optional LAST_EXIT_CODE)
        if ($exit_code == null) or ($exit_code == 0) {
            exit 1
        }
        exit $exit_code
    }
}

def --wrapped main [
    ...args # Wrapper flags, one or more secret ids, then command and arguments to run.
] {
    mut remaining = ($args | each { |arg| $arg | into string })

    if (($remaining | get 0?) == "--") {
        $remaining = ($remaining | skip 1)
    }

    if ($remaining | is-empty) {
        print --stderr $usage
        exit 64
    }

    if (($remaining | length) == 1) and (($remaining.0 == "--help") or ($remaining.0 == "-h")) {
        print $usage
        exit 0
    }

    mut isolated = false
    mut env_name = null
    mut parsing_flags = true

    while $parsing_flags and (not ($remaining | is-empty)) {
        let arg = ($remaining | get 0?)

        if $arg == "--" {
            $remaining = ($remaining | skip 1)
            $parsing_flags = false
        } else if $arg == "--isolated" {
            $isolated = true
            $remaining = ($remaining | skip 1)
        } else if $arg == "--env-name" {
            $env_name = (parse_flag_value $arg $remaining)
            $remaining = ($remaining | skip 2)
        } else if ($arg | str starts-with "--env-name=") {
            $env_name = ($arg | str replace "--env-name=" "")
            $remaining = ($remaining | skip 1)
        } else if ($arg == "--help") or ($arg == "-h") {
            print $usage
            exit 0
        } else {
            $parsing_flags = false
        }
    }

    if ($remaining | is-empty) {
        print --stderr $usage
        exit 64
    }

    let separator = ($remaining | enumerate | where item == "--" | get 0?)
    let secret_ids = if $separator == null {
        [$remaining.0]
    } else {
        $remaining | take $separator.index
    }

    mut command = if $separator == null {
        $remaining | skip 1
    } else {
        $remaining | skip ($separator.index + 1)
    }

    if (($command | get 0?) == "--") {
        $command = ($command | skip 1)
    }

    if ($secret_ids | is-empty) or ($command | is-empty) {
        print --stderr $usage
        exit 64
    }

    if ($env_name != null) and (($secret_ids | length) != 1) {
        print --stderr "with-bws-secret: --env-name can only be used with one secret id"
        exit 64
    }

    if (which bws | is-empty) {
        print --stderr "with-bws-secret: bws was not found in PATH"
        exit 127
    }

    let access_token = ($env | get --optional $access_token_env)
    if ($access_token == null) or ($access_token == "") {
        print --stderr $"with-bws-secret: ($access_token_env) must be set for --access-token"
        exit 78
    }

    mut injected_env = {}
    mut isolated_env = []

    for secret_id in $secret_ids {
        let secret = (fetch_secret $access_token $secret_id)
        let secret_key = if ($env_name == null) {
            $secret.key
        } else {
            $env_name
        }

        validate_env_name $secret_key
        if ($injected_env | columns | any { |name| $name == $secret_key }) {
            print --stderr $"with-bws-secret: duplicate environment variable name from secret ($secret_id): ($secret_key)"
            exit 64
        }

        let secret_value = $secret.value
        if $secret_value == null {
            print --stderr $"with-bws-secret: secret ($secret_id) has no value"
            exit 1
        }

        $injected_env = ($injected_env | merge { $secret_key: $secret_value })
        $isolated_env = ($isolated_env | append $"($secret_key)=($secret_value)")
    }

    if $isolated {
        ^env -i ...$isolated_env ...$command
        exit $env.LAST_EXIT_CODE
    }

    let child_command = $command
    with-env $injected_env {
        run-external ...$child_command
    }
    exit $env.LAST_EXIT_CODE
}
