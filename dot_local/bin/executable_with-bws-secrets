#!/usr/bin/env nu

const usage = "Usage: with-bws-secrets [--isolated] COMMAND [ARG...]

Run COMMAND with Bitwarden Secrets Manager values injected by bws.

Options:
  --isolated  Do not pass the current environment through to COMMAND.
  -h, --help  Show this help.

Examples:
  with-bws-secrets codex
  with-bws-secrets opencode
  with-bws-secrets --isolated env"

const access_token_env = "BWS_AUTH_TOKEN"

def --wrapped main [
    ...args: string # Wrapper flags followed by command and arguments to run through bws.
] {
    mut command = $args

    if (($command | get 0?) == "--") {
        $command = ($command | skip 1)
    }

    if ($command | is-empty) {
        print --stderr $usage
        exit 64
    }

    if (($command | length) == 1) and (($command.0 == "--help") or ($command.0 == "-h")) {
        print $usage
        exit 0
    }

    mut isolated = false
    if (($command | get 0?) == "--isolated") {
        $isolated = true
        $command = ($command | skip 1)
    }

    if (($command | get 0?) == "--") {
        $command = ($command | skip 1)
    }

    if ($command | is-empty) {
        print --stderr $usage
        exit 64
    }

    if (which bws | is-empty) {
        print --stderr "with-bws-secrets: bws was not found in PATH"
        exit 127
    }

    let access_token = ($env | get --optional $access_token_env)
    if ($access_token == null) or ($access_token == "") {
        print --stderr $"with-bws-secrets: ($access_token_env) must be set for --access-token"
        exit 78
    }

    let bws_args = if $isolated {
        ["run", "--no-inherit-env", "--"]
    } else {
        ["run", "--"]
    }

    ^bws --access-token $access_token ...$bws_args ...$command
    exit $env.LAST_EXIT_CODE
}
