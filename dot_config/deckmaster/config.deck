[[keys]]
  index = 0
  [keys.action]
    exec = "kitty btop"
  [keys.widget]
    id = "top"
    [keys.widget.config]
      mode = "cpu"
      fillColor = "#d497de"

[[keys]]
  index = 1
  [keys.action]
    exec = "kitty btop"
  [keys.widget]
    id = "top"
    [keys.widget.config]
      mode = "memory"

[[keys]]
  index = 2
  [keys.action]
    exec = "kitty /home/celeste/.local/bin/runweather.sh"
  [keys.widget]
    id = "weather"
    [keys.widget.config]
      location = "Bogotá"

[[keys]]
  index = 3
  [keys.widget]
    id = "time"
    [keys.widget.config]
      format = "%l;%d;%M"
      font = "regular;bold;regular"

[[keys]]
  index = 4
  [keys.widget]
    id = "time"
    [keys.widget.config]
      format = "%H;%i;%s"
      font = "bold;regular;thin"

[[keys]]
  index = 5
  [keys.widget]
    id = "button"
    [keys.widget.config]
      icon = "/home/celeste/.config/deckmaster/assets/audio-volume-low-symbolic-white.png"
      fontsize = 8
  [keys.action]
    keycode = "VolumeDown"
  [keys.action_hold]
    keycode = "Mute"

[[keys]]
  index = 6
  [keys.widget]
    id = "button"
    [keys.widget.config]
      icon = "/home/celeste/.config/deckmaster/assets/audio-volume-high-symbolic-white.png"
      fontsize = 8
  [keys.action]
    keycode = "VolumeUp"
  [keys.action_hold]
    keycode = "Mute"

[[keys]]
  index = 7
  [keys.widget]
    id = "button"
    [keys.widget.config]
      icon = "/home/celeste/.config/deckmaster/assets/media-playback-pause-symbolic-white.png"
  [keys.action]
    exec = "playerctl play-pause"

[[keys]]
  index = 8
  [keys.widget]
    id = "button"
    [keys.widget.config]
      icon = "/home/celeste/.config/deckmaster/assets/go-previous-symbolic-white.png"
  [keys.action]
    exec = "playerctl previous"

[[keys]]
  index = 9
  [keys.widget]
    id = "button"
    [keys.widget.config]
      icon = "/home/celeste/.config/deckmaster/assets/go-next-symbolic-white.png"
  [keys.action]
    exec = "playerctl next"

[[keys]]
  index = 10
  [keys.widget]
    id = "button"
    [keys.widget.config]
      icon = "/home/celeste/.config/deckmaster/assets/star-new-symbolic-white.png"
  [keys.action]
    exec = "elgato-keylight-cli --ip 192.168.0.11 --port 9123 toggle"

[[keys]]
  index = 11
  [keys.widget]
    id = "button"
    [keys.widget.config]
      icon = "/home/celeste/.config/deckmaster/assets/pan-down-symbolic-white.png"
  [keys.action]
    exec = "elgato-keylight-cli --ip 192.168.0.11 --port 9123 decr-brightness"

[[keys]]
  index = 12
  [keys.widget]
    id = "button"
    [keys.widget.config]
      icon = "/home/celeste/.config/deckmaster/assets/system-shutdown-symbolic-white.png"
  [keys.action]
    device = "sleep"

[[keys]]
  index = 13
  [keys.widget]
    id = "button"
    [keys.widget.config]
      icon = "/home/celeste/.config/deckmaster/assets/pan-up-symbolic-white.png"
  [keys.action]
    exec = "elgato-keylight-cli --ip 192.168.0.11 --port 9123 incr-brightness"
